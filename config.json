{
  "bot_name": "Pingu",
  "version": "2.0",
  "couple": "Bonz & Ella",
  "voice_settings": {
    "rate": 0.95,
    "pitch": 1.1,
    "voice_preference": "warm female",
    "auto_speak": true,
    "language": "en-US"
  },
  "interface": {
    "show_text_input": true,
    "mic_animation": true,
    "theme": "dark warm",
    "avatar_mood": "attentive"
  },
  "data_settings": {
    "whatsapp_import": true,
    "max_chat_history": 200,
    "fuzzy_match_threshold": 0.75,
    "enable_faq_mappings": true,
    "strict_matching": false,
    "fallback_on_no_match": true
  },
  "search_settings": {
    "prioritize": [
      "specific_facts",
      "first_meeting",
      "rainy_evening_confession",
      "relationship_development"
    ],
    "semantic_search": true,
    "keyword_weight": 0.8
  },
  "responses": {
    "on_unknown": "I don't have that memory yet. Want to tell me about it? 💕",
    "on_error": "Let me try that again...",
    "max_response_length": 300
  }
}

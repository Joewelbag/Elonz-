{
  "bot": {
    "name": "Pingu",
    "version": "2.0.0",
    "environment": "production",
    "debug_mode": false
  },
  "voice": {
    "input": {
      "language": "en-US",
      "continuous_mode": true,
      "interim_results": true,
      "max_alternatives": 1,
      "silence_timeout_ms": 2000
    },
    "output": {
      "rate": 0.95,
      "pitch": 1.0,
      "volume": 1.0,
      "voice_preference": "natural",
      "auto_speak": true,
      "queue_speeches": true
    },
    "full_duplex": {
      "enabled": true,
      "long_press_ms": 500,
      "continuous_listening": true,
      "auto_restart": true
    }
  },
  "interface": {
    "theme": {
      "primary": "#0f0f0f",
      "secondary": "#1a1a1a",
      "accent": "#00ff9d",
      "text": "#ffffff",
      "text_secondary": "#a0a0a0",
      "border": "#2a2a2a"
    },
    "animations": {
      "pulse_speed": 1.5,
      "wave_speed": 0.8,
      "transition_speed": 0.3
    },
    "mic": {
      "idle_border": "#00ff9d",
      "listening_pulse": true,
      "duplex_symbol": "∞",
      "show_level_meter": true
    },
    "keyboard": {
      "floating": true,
      "toggle_on_first_tap": true,
      "close_on_second_tap": true
    }
  },
  "memory": {
    "file": "memory.json",
    "auto_reload": true,
    "cache_duration_ms": 300000,
    "max_history": 100
  },
  "ai": {
    "matching": {
      "fuzzy_threshold": 0.75,
      "semantic_search": true,
      "keyword_weight": 0.8,
      "context_weight": 0.2
    },
    "responses": {
      "typing_delay_min_ms": 400,
      "typing_delay_max_ms": 1200,
      "think_time_ms": 800
    },
    "context": {
      "remember_last": 5,
      "conversation_window": true,
      "follow_up_detection": true
    }
  },
  "performance": {
    "offline_mode": true,
    "cache_ttl": 86400,
    "max_message_length": 500,
    "rate_limit_ms": 100
  }
}